<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.BookShop_Mobile" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/accentColor</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/defBackground</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
        <!-- Customize your theme here. -->
        <item name="android:buttonStyle">@style/BtnStyle</item>

        <item name="android:fontFamily">@font/montserrat_regular</item>

    </style>
    <style name="AppTheme" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Default text -->
        <item name="android:fontFamily">@font/montserrat_regular</item>

        <!-- Buttons -->
        <item name="buttonStyle">@style/MyButtonStyle</item>
    </style>

    <style name="MyButtonStyle" parent="Widget.Material3.Button">
        <item name="android:fontFamily">@font/montserrat_regular</item>
    </style>
</resources>